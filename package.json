{
  "name": "grocery-list",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"vite --port 5173\" \"wrangler pages dev dist --port 8787 --compatibility-date=2024-09-23\"",
    "build": "vite build",
    "preview": "wrangler pages dev dist --compatibility-date=2024-09-23",
    "deploy": "vite build && wrangler pages deploy dist",
    "db:init:local": "wrangler d1 execute grocery-list-db --local --file=schema.sql",
    "db:init": "wrangler d1 execute grocery-list-db --file=schema.sql"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "hono": "^4.6.14",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.11",
    "concurrently": "^9.1.2",
    "jsdom": "^29.1.1",
    "vite": "^6.0.11",
    "vitest": "^4.1.10",
    "wrangler": "^3.103.1"
  }
}
